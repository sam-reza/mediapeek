{
  "name": "@mediapeek/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && oxlint packages/shared",
    "clean": "rm -rf dist node_modules"
  },
  "devDependencies": {
    "@mediapeek/config-typescript": "workspace:*",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.2"
  },
  "exports": {
    "./analyze-contract": {
      "types": "./dist/analyze-contract.d.ts",
      "default": "./src/analyze-contract.ts"
    },
    "./analyze-progress": {
      "types": "./dist/analyze-progress.d.ts",
      "default": "./src/analyze-progress.ts"
    },
    "./archive-inspection": {
      "types": "./dist/archive-inspection.d.ts",
      "default": "./src/archive-inspection.ts"
    },
    "./telemetry": {
      "types": "./dist/telemetry.d.ts",
      "default": "./src/telemetry.ts"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./src/schemas.ts"
    },
    "./media": {
      "types": "./dist/media.d.ts",
      "default": "./src/media.ts"
    },
    "./filename-resolution": {
      "types": "./dist/filename-resolution.d.ts",
      "default": "./src/filename-resolution.ts"
    },
    "./media-info-result": {
      "types": "./dist/media-info-result.d.ts",
      "default": "./src/media-info-result.ts"
    },
    "./runtime-config": {
      "types": "./dist/runtime-config.d.ts",
      "default": "./src/runtime-config.ts"
    },
    "./log-redaction": {
      "types": "./dist/log-redaction.d.ts",
      "default": "./src/log-redaction.ts"
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
