{
  "name": "@mediapeek/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "default": "./src/components/*.tsx"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "default": "./src/hooks/*.ts"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./src/lib/*.ts"
    },
    "./styles/*": "./src/styles/*.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "cd ../.. && oxlint packages/ui",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^12.38.0",
    "remix-themes": "^2.0.4",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@mediapeek/config-typescript": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.2",
    "vite": "8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
